    sys.exit('Not yet implemented.')


def get_paste(url):
    paste_key = get_paste_key(url)
    print(f'Paste key: {paste_key}')

    #TODO
    sys.exit('Not yet implemented.')


def main():
    if not sys.stdin.isatty():
        pipe_input = ""
        for line in sys.stdin:
            pipe_input += line
        url = create_paste(pipe_input)
        print(url)

    else:
        # Get paste
        args = parse_args()
        if not args.url:
            sys.exit(f'{text_red}Error: URL is required.')
        get_paste(args.url)

if __name__ == '__main__':
  main()

