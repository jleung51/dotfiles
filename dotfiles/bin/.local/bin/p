#!/usr/bin/env python3
#
# Pastebin API documentation:
# https://pastebin.com/doc_api
#
# Setup:
# pip3 install requests

import argparse
import requests
import subprocess
import sys

text_red = '\033[0;31m'
text_no_color = '\033[0m'


def parse_args():
    parser = argparse.ArgumentParser()
    parser.add_argument('url', nargs='?', help='URL of the paste.')

    args = parser.parse_args()
    if args.url:
        if 'pastebin.com/' not in args.url:
            sys.exit(f'{text_red}Error: Is this a valid Pastebin URL?{text_no_color}')

    return args


def get_paste_key(url):
    return url.replace('https://', '').replace('pastebin.com/', '')


